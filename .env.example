# Copie este arquivo para `.env` e preencha com suas credenciais
# NÃO faça commit do arquivo `.env` com credenciais reais

# Conta de envio (ex: Gmail)
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua_senha_de_app_ou_senha

# Destinatário (opcional) — por padrão envia para EMAIL_USER
EMAIL_TO=destino@exemplo.com

# SMTP host/port (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Porta do servidor local
PORT=3000
